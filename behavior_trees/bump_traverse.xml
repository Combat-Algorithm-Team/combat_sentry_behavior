<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <BehaviorTree ID="traverse_bump_segment">
    <Sequence>
      <PubNav2Goal goal="{bump_before_goal}"
                   topic_name="goal_pose"
                   success_distance_tolerance="0.15"
                   nav_observation_timeout="2000"/>
      <PublishBumpStatus bump_status="1"
                         duration="0.0"
                         topic_name="bump_status"/>
      <WaitForSentryInfoState expected_state="3"
                              timeout="5000.0"
                              key_port="{@referee_sentryInfo}"/>
      <RecoveryNode num_attempts="999">
        <Timeout msec="10000">
          <PubNav2Goal goal="{bump_after_goal}"
                       topic_name="goal_pose"
                       success_distance_tolerance="0.15"
                       nav_observation_timeout="2000"/>
        </Timeout>
        <Parallel success_count="1"
                  failure_count="2">
          <Sleep msec="5000"/>
          <KeepRunningUntilFailure>
            <PubNav2Goal goal="{bump_before_goal}"
                         topic_name="goal_pose"
                         success_distance_tolerance="0.15"
                         nav_observation_timeout="2000"/>
          </KeepRunningUntilFailure>
        </Parallel>
      </RecoveryNode>
      <PublishBumpStatus bump_status="0"
                         duration="0.0"
                         topic_name="bump_status"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="traverse_bump_from_ally">
    <SubTree ID="traverse_bump_segment"
             bump_before_goal="{bump_from_ally_before_goal}"
             bump_after_goal="{bump_from_ally_after_goal}"/>
  </BehaviorTree>

  <BehaviorTree ID="traverse_bump_to_ally">
    <SubTree ID="traverse_bump_segment"
             bump_before_goal="{bump_from_ally_after_goal}"
             bump_after_goal="{bump_from_ally_before_goal}"/>
  </BehaviorTree>

</root>
