<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <BehaviorTree ID="rmuc_2026_check_game_start">
    <ReactiveFallback>
      <IsGameStatus name="RMUC2026IsGameStart"
                    max_remain_time="420"
                    min_remain_time="0"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"/>
      <SubTree ID="rmuc_2026_hold_preparation"/>
      <SubTree ID="rmuc_2026_hold_self_checking"/>
      <SubTree ID="rmuc_2026_hold_before_running"/>
    </ReactiveFallback>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_hold_preparation">
    <ReactiveSequence>
      <IsGameStatus name="RMUC2026Preparation"
                    max_remain_time="180"
                    min_remain_time="0"
                    expected_game_progress="1"
                    key_port="{@referee_gameStatus}"/>
      <KeepRunningUntilFailure>
        <Sequence>
          <PublishChassisStatus chassis_status="25"
                                duration="0.0"
                                topic_name="cmd_chassis_status"/>
          <PublishSentryStatus sentry_status="3"
                               duration="0.0"
                               topic_name="cmd_sentry_status"/>
          <PublishTargetMode cmd_target_mode="1"
                             duration="0.0"
                             topic_name="cmd_target_mode"/>
          <PubNav2Goal goal="-0.1;0.0;0.0"
                       topic_name="goal_pose"/>
        </Sequence>
      </KeepRunningUntilFailure>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_hold_self_checking">
    <ReactiveSequence>
      <Fallback>
        <IsGameStatus name="RMUC2026SelfChecking"
                      max_remain_time="15"
                      min_remain_time="0"
                      expected_game_progress="2"
                      key_port="{@referee_gameStatus}"/>
        <IsGameStatus name="RMUC2026CountDown"
                      max_remain_time="5"
                      min_remain_time="0"
                      expected_game_progress="3"
                      key_port="{@referee_gameStatus}"/>
      </Fallback>
      <KeepRunningUntilFailure>
        <Sequence>
          <PublishChassisStatus chassis_status="0"
                                duration="0.0"
                                topic_name="cmd_chassis_status"/>
          <PublishSentryStatus sentry_status="3"
                               duration="0.0"
                               topic_name="cmd_sentry_status"/>
          <PublishTargetMode cmd_target_mode="0"
                             duration="0.0"
                             topic_name="cmd_target_mode"/>
          <PublishTwist v_y="0.0"
                        v_yaw="0.0"
                        v_x="0.0"
                        duration="0.0"
                        topic_name="cmd_vel"/>
        </Sequence>
      </KeepRunningUntilFailure>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_hold_before_running">
    <KeepRunningUntilFailure>
      <Sequence>
        <PublishChassisStatus chassis_status="0"
                              duration="0.0"
                              topic_name="cmd_chassis_status"/>
        <PublishSentryStatus sentry_status="0"
                             duration="0.0"
                             topic_name="cmd_sentry_status"/>
        <PublishTargetMode cmd_target_mode="0"
                           duration="0.0"
                           topic_name="cmd_target_mode"/>
        <PublishTwist v_y="0.0"
                      v_yaw="0.0"
                      v_x="0.0"
                      duration="0.0"
                      topic_name="cmd_vel"/>
      </Sequence>
    </KeepRunningUntilFailure>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_reset_target_mode_to_armor">
    <PublishTargetMode cmd_target_mode="1"
                       duration="0.0"
                       topic_name="cmd_target_mode"/>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_control_robot_status">
    <ReactiveFallback>
      <Sequence>
        <IsRfidDetected key_port="{@referee_rfidStatus}"
                        enemy_fortress_gain_point="true"/>
        <Sequence>
          <PublishChassisStatus chassis_status="255"
                                duration="500.0"
                                topic_name="cmd_chassis_status"/>
          <PublishChassisStatus chassis_status="200"
                                duration="500.0"
                                topic_name="cmd_chassis_status"/>
        </Sequence>
      </Sequence>
      <Sequence>
        <IsAttacked robotstatus_port="{@referee_robotStatus}"
                    hurtdata_port="{@referee_hurtData}"/>
        <Sequence>
          <PublishChassisStatus chassis_status="200"
                                duration="500.0"
                                topic_name="cmd_chassis_status"/>
          <PublishChassisStatus chassis_status="150"
                                duration="500.0"
                                topic_name="cmd_chassis_status"/>
        </Sequence>
      </Sequence>
      <Sequence>
        <IsDetectEnemy armor_id="8"
                       max_distance="10.0"
                       key_port="{@tracker_target}"/>
        <PublishChassisStatus chassis_status="0"
                              duration="0.0"
                              topic_name="cmd_chassis_status"/>
      </Sequence>
      <Sequence>
        <IsDetectEnemy armor_id="1;2;3;4;7"
                       max_distance="6.0"
                       key_port="{@tracker_target}"/>
        <Sequence>
          <PublishChassisStatus chassis_status="200"
                                duration="500.0"
                                topic_name="cmd_chassis_status"/>
          <PublishChassisStatus chassis_status="150"
                                duration="500.0"
                                topic_name="cmd_chassis_status"/>
        </Sequence>
      </Sequence>
      <Sequence>
        <IsRfidDetected key_port="{@referee_rfidStatus}"
                         ally_fortress_gain_point="true"/>
        <Sequence>
          <PublishChassisStatus chassis_status="100"
                                duration="500.0"
                                topic_name="cmd_chassis_status"/>
          <PublishChassisStatus chassis_status="50"
                                duration="300.0"
                                topic_name="cmd_chassis_status"/>
        </Sequence>
      </Sequence>
      <PublishChassisStatus chassis_status="25"
                            duration="0.0"
                            topic_name="cmd_chassis_status"/>
    </ReactiveFallback>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_control_sentry_status">
    <ReactiveFallback>
      <Sequence>
        <Inverter>
          <IsStatusOK hp_min="200"
                      hp_max="400"
                      key_port="{@referee_robotStatus}"/>
        </Inverter>
        <PublishSentryStatus sentry_status="2"
                             duration="0.0"
                             topic_name="cmd_sentry_status"/>
      </Sequence>
      <Sequence>
        <IsDetectEnemy armor_id="8"
                       max_distance="10.0"
                       key_port="{@tracker_target}"/>
        <PublishSentryStatus sentry_status="1"
                             duration="0.0"
                             topic_name="cmd_sentry_status"/>
      </Sequence>
      <Sequence>
        <IsDetectEnemy armor_id="1;2;3;4;7"
                       max_distance="6.0"
                       key_port="{@tracker_target}"/>
        <PublishSentryStatus sentry_status="1"
                             duration="0.0"
                             topic_name="cmd_sentry_status"/>
      </Sequence>
      <PublishSentryStatus sentry_status="3"
                           duration="0.0"
                           topic_name="cmd_sentry_status"/>
    </ReactiveFallback>
  </BehaviorTree>

</root>
