<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="check_game_start">
    <Fallback>
      <IsGameStatus name="IsGameStart"
                    max_remain_time="420"
                    min_remain_time="0"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"/>
      <ForceFailure>
        <Sequence>
          <PublishChassisStatus chassis_status="0"
                                duration="0.0"
                                topic_name="cmd_chassis_status"/>
          <PublishSentryStatus sentry_status="0"
                               duration="0.0"
                               topic_name="cmd_sentry_status"/>
          <PublishTwist v_y="0.0"
                        v_yaw="0.0"
                        v_x="0.0"
                        duration="0.0"
                        topic_name="cmd_vel"/>
          <PubNav2Goal goal="0;0;0"
                       topic_name="goal_pose"
                       status_port="{@nav2_navigate_to_pose_status}"
                       feedback_port="{@nav2_navigate_to_pose_feedback}"
                       plan_port="{@nav2_plan}"
                       success_distance_tolerance="0.15"
                       nav_observation_timeout="2000"
                       distance_remaining="{nav_distance_remaining}"
                       path_remaining="{nav_path_remaining}"
                       nav_status_code="{nav_status_code}"/>
        </Sequence>
      </ForceFailure>
    </Fallback>
  </BehaviorTree>

  <BehaviorTree ID="control_robot_status">
    <ReactiveFallback>
      <Sequence>
        <Fallback>
          <IsAttacked robotstatus_port="{@referee_robotStatus}"
                      hurtdata_port="{@referee_hurtData}"/>
          <IsRfidDetected ally_supply_point_non_exchange="false"
                          center_gain_point="true"
                          key_port="{@referee_rfidStatus}"/>
          <IsDetectEnemy armor_id="1;2;3;4;7"
                        max_distance="6.0"
                        key_port="{@detector_armors}"/>
        </Fallback>
        <Sequence>
          <PublishChassisStatus chassis_status="255"
                                duration="500.0"
                                topic_name="cmd_chassis_status"/>
          <PublishChassisStatus chassis_status="200"
                                duration="300.0"
                                topic_name="cmd_chassis_status"/>
        </Sequence>
      </Sequence>
      <Sequence>
        <CheckFieldEvent key_port="{@referee_eventData}"
                          center_gain_point="0"/>
        <PublishChassisStatus chassis_status="100"
                              duration="0.0"
                              topic_name="cmd_chassis_status"/>
      </Sequence>
      <Sequence>
        <PublishChassisStatus chassis_status="200"
                              duration="500.0"
                              topic_name="cmd_chassis_status"/>
        <PublishChassisStatus chassis_status="150"
                              duration="300.0"
                              topic_name="cmd_chassis_status"/>
      </Sequence>
    </ReactiveFallback>
  </BehaviorTree>

  <BehaviorTree ID="control_sentry_status">
    <ReactiveFallback>
      <Sequence>
        <Inverter>
          <IsStatusOK hp_min="200"
                      hp_max="399"
                      key_port="{@referee_robotStatus}"/>
        </Inverter>
        <PublishSentryStatus sentry_status="2"
                             duration="0.0"
                             topic_name="cmd_sentry_status"/>
      </Sequence>
      <Sequence>
        <IsDetectEnemy armor_id="1;2;3;4;7"
                       max_distance="6.0"
                       key_port="{@detector_armors}"/>
        <PublishSentryStatus sentry_status="1"
                             duration="0.0"
                             topic_name="cmd_sentry_status"/>
      </Sequence>
      <Sequence>
        <IsRfidDetected ally_supply_point_non_exchange="true"
                        center_gain_point="true"
                        key_port="{@referee_rfidStatus}"/>
        <PublishSentryStatus sentry_status="2"
                             duration="0.0"
                             topic_name="cmd_sentry_status"/>
      </Sequence>
      <PublishSentryStatus sentry_status="3"
                           duration="0.0"
                           topic_name="cmd_sentry_status"/>
    </ReactiveFallback>
  </BehaviorTree>

  <BehaviorTree ID="calculate_attack_pose">
    <Sequence>
      <IsDetectEnemy armor_id="1;2;3;4;7"
                      max_distance="6.0"
                      key_port="{@detector_armors}"/>
      <CalculateAttackPose costmap_port="{@nav_globalCostmap}"
                           tracker_port="{@tracker_target}"
                           goal="{attack_pose}"
                           topic_name="debug_attack_pose"/>
      <IsGoalAvailable max_x="8.0"
                       max_y="8.0"
                       goal="{attack_pose}"/>
      <PubNav2Goal goal="{attack_pose}"
                   topic_name="goal_pose"
                   status_port="{@nav2_navigate_to_pose_status}"
                   feedback_port="{@nav2_navigate_to_pose_feedback}"
                   plan_port="{@nav2_plan}"
                   success_distance_tolerance="0.15"
                   nav_observation_timeout="2000"
                   distance_remaining="{nav_distance_remaining}"
                   path_remaining="{nav_path_remaining}"
                   nav_status_code="{nav_status_code}"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="check_min_hp">
    <ReactiveSequence>
      <Inverter>
        <IsStatusOK hp_min="200"
                    hp_max="399"
                    key_port="{@referee_robotStatus}"/>
      </Inverter>
      <Fallback>
        <Sequence>
          <IsRfidDetected ally_supply_point_non_exchange="true"
                          center_gain_point="false"
                          key_port="{@referee_rfidStatus}"/>
          <PublishSentryStatus sentry_status="2"
                               duration="0.0"
                               topic_name="cmd_sentry_status"/>
        </Sequence>
        <Sequence>
          <PublishSentryStatus sentry_status="2"
                               duration="0.0"
                               topic_name="cmd_sentry_status"/>
          <PubNav2Goal goal="0;0;0"
                       topic_name="goal_pose"
                       status_port="{@nav2_navigate_to_pose_status}"
                       feedback_port="{@nav2_navigate_to_pose_feedback}"
                       plan_port="{@nav2_plan}"
                       success_distance_tolerance="0.15"
                       nav_observation_timeout="2000"
                       distance_remaining="{nav_distance_remaining}"
                       path_remaining="{nav_path_remaining}"
                       nav_status_code="{nav_status_code}"/>
        </Sequence>
      </Fallback>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="waypoint_mission">
    <Sequence>
      <!-- 航点任务：低血量恢复后整组任务会从第一个航点重新执行 -->
      <PubNav2Goal goal="3.5;5.5;0"
                   topic_name="goal_pose"
                   status_port="{@nav2_navigate_to_pose_status}"
                   feedback_port="{@nav2_navigate_to_pose_feedback}"
                   plan_port="{@nav2_plan}"
                   success_distance_tolerance="0.15"
                   nav_observation_timeout="2000"
                   distance_remaining="{nav_distance_remaining}"
                   path_remaining="{nav_path_remaining}"
                   nav_status_code="{nav_status_code}"/>
      <PubNav2Goal goal="2.5;6.5;0"
                   topic_name="goal_pose"
                   status_port="{@nav2_navigate_to_pose_status}"
                   feedback_port="{@nav2_navigate_to_pose_feedback}"
                   plan_port="{@nav2_plan}"
                   success_distance_tolerance="0.15"
                   nav_observation_timeout="2000"
                   distance_remaining="{nav_distance_remaining}"
                   path_remaining="{nav_path_remaining}"
                   nav_status_code="{nav_status_code}"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="decide_goal">
    <ForceSuccess>
      <ReactiveFallback>
        <SubTree ID="check_min_hp"/>
        <Fallback>
          <SubTree ID="calculate_attack_pose"/>
          <SubTree ID="waypoint_mission"/>
        </Fallback>
      </ReactiveFallback>
    </ForceSuccess>
  </BehaviorTree>

  <BehaviorTree ID="rmul_2026">
    <KeepRunningUntilFailure>
      <ForceSuccess>
        <ReactiveSequence>
          <SubTree ID="check_game_start"/>
          <Parallel success_count="1"
                    failure_count="1">
            <SubTree ID="decide_goal"/>
            <KeepRunningUntilFailure>
              <SubTree ID="control_robot_status"/>
            </KeepRunningUntilFailure>
            <KeepRunningUntilFailure>
              <SubTree ID="control_sentry_status"/>
            </KeepRunningUntilFailure>
          </Parallel>
        </ReactiveSequence>
      </ForceSuccess>
    </KeepRunningUntilFailure>
  </BehaviorTree>

</root>
