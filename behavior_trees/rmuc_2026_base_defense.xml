<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <BehaviorTree ID="rmuc_2026_defend_base_under_highland">
    <ReactiveSequence>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="false"/>
      <IsBaseHpLow hp_threshold="1000"
                   key_port="{@referee_gameRobotHp}"/>
      <PubNav2Goal goal="{@rmuc_fortress_guard_goal}"
                   topic_name="goal_pose"/>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_defend_base_from_highland">
    <ReactiveSequence>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="true"/>
      <IsBaseHpLow hp_threshold="1000"
                   key_port="{@referee_gameRobotHp}"/>
      <SubTree ID="traverse_bump_segment"
               bump_before_goal="{@rmuc_bump_to_highland_after_goal}"
               bump_after_goal="{@rmuc_bump_to_highland_before_goal}"/>
      <PubNav2Goal goal="{@rmuc_bump_slope_start_goal}"
                   topic_name="goal_pose"/>
      <SetMissionFlag flag="rmuc_phase_on_highland"
                      value="false"/>
      <PubNav2Goal goal="{@rmuc_fortress_guard_goal}"
                   topic_name="goal_pose"/>
    </ReactiveSequence>
  </BehaviorTree>

</root>
