<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <BehaviorTree ID="rmuc_2026_defend_base_under_highland">
    <ReactiveSequence>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="false"
                        default_value="false"/>
      <IsBaseHpLow hp_threshold="600"
                   key_port="{@referee_gameRobotHp}"/>
      <PublishTargetMode target_mode="0"
                         duration="0.0"
                         topic_name="target_mode"/>
      <PubNav2Goal goal="{rmuc_fortress_guard_goal}"
                   topic_name="goal_pose"/>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_defend_base_from_highland">
    <ReactiveSequence>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="true"
                        default_value="false"/>
      <IsBaseHpLow hp_threshold="600"
                   key_port="{@referee_gameRobotHp}"/>
      <PublishTargetMode target_mode="0"
                         duration="0.0"
                         topic_name="target_mode"/>
      <SubTree ID="traverse_bump_segment"
               bump_before_goal="{rmuc_bump_from_highland_before_goal}"
               bump_after_goal="{rmuc_bump_from_highland_after_goal}"/>
      <SetMissionFlag flag="rmuc_phase_on_highland"
                      value="false"/>
      <PubNav2Goal goal="{rmuc_fortress_guard_goal}"
                   topic_name="goal_pose"/>
    </ReactiveSequence>
  </BehaviorTree>

</root>
