<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <BehaviorTree ID="rmuc_2026_attack_outpost_once">
    <Sequence>
      <CheckMissionFlag flag="rmuc_outpost_attack_done"
                        expected="false"/>
      <RecoveryNode num_attempts="999">
        <Sequence>
          <PublishTargetMode target_mode="2"
                             duration="0.0"
                             topic_name="cmd_target_mode"/>
          <PubNav2Goal goal="{rmuc_enemy_outpost_attack_goal}"
                       topic_name="goal_pose"/>
          <WaitForTargetLostStable target_id="8"
                                   lost_duration="5000.0"
                                   key_port="{@tracker_target}"/>
          <PublishTargetMode target_mode="1"
                             duration="0.0"
                             topic_name="cmd_target_mode"/>
          <SetMissionFlag flag="rmuc_outpost_attack_done"
                          value="true"/>
        </Sequence>
        <ForceSuccess>
          <Sequence>
            <PublishTargetMode target_mode="2"
                               duration="0.0"
                               topic_name="cmd_target_mode"/>
            <PubNav2Goal goal="{rmuc_enemy_outpost_attack_goal}"
                         topic_name="goal_pose"/>
          </Sequence>
        </ForceSuccess>
      </RecoveryNode>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_small_power_rune_ready">
    <Sequence>
      <CheckMissionCounter counter="rmuc_small_power_rune_activation_failures"
                           max_count="2"/>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="false"/>
      <IsGameStatus name="RMUC2026SmallPowerRuneTime"
                    max_remain_time="420"
                    min_remain_time="240"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"/>
      <CheckFieldEvent key_port="{@referee_eventData}"
                       ally_small_power_rune="0"/>
      <CheckSentryInfo key_port="{@referee_sentryInfo}"
                       ally_power_rune_state="1"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_activate_power_rune_if_ready">
    <Sequence>
      <ReactiveSequence>
        <SubTree ID="rmuc_2026_small_power_rune_ready"/>
        <PubNav2Goal goal="{rmuc_trapezoid_low_platform_goal}"
                     topic_name="goal_pose"/>
      </ReactiveSequence>
      <PublishTargetMode target_mode="3"
                         duration="0.0"
                         topic_name="cmd_target_mode"/>
      <ReactiveFallback>
        <Sequence>
          <CheckFieldEvent key_port="{@referee_eventData}"
                           ally_small_power_rune="1"/>
          <PublishTargetMode target_mode="1"
                             duration="0.0"
                             topic_name="cmd_target_mode"/>
        </Sequence>
        <Sequence>
          <WaitForSentryInfoState expected_state="-1"
                                  ally_power_rune_state="0"
                                  timeout="0.0"
                                  key_port="{@referee_sentryInfo}"/>
          <ReactiveFallback>
            <Sequence>
              <CheckFieldEvent key_port="{@referee_eventData}"
                               ally_small_power_rune="1"/>
              <PublishTargetMode target_mode="1"
                                 duration="0.0"
                                 topic_name="cmd_target_mode"/>
            </Sequence>
            <ForceFailure>
              <Sequence>
                <WaitForSentryInfoState expected_state="-1"
                                        ally_power_rune_state="1"
                                        timeout="0.0"
                                        key_port="{@referee_sentryInfo}"/>
                <PublishTargetMode target_mode="1"
                                   duration="0.0"
                                   topic_name="cmd_target_mode"/>
                <IncrementMissionCounter counter="rmuc_small_power_rune_activation_failures"
                                         step="1"
                                         max_count="2"/>
              </Sequence>
            </ForceFailure>
          </ReactiveFallback>
        </Sequence>
      </ReactiveFallback>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_enter_highland">
    <Sequence>
      <PubNav2Goal goal="{rmuc_bump_slope_start_goal}"
                   topic_name="goal_pose"/>
      <SubTree ID="traverse_bump_segment"
               bump_before_goal="{rmuc_bump_to_highland_before_goal}"
               bump_after_goal="{rmuc_bump_to_highland_after_goal}"/>
      <SetMissionFlag flag="rmuc_phase_on_highland"
                      value="true"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_under_highland_tasks">
    <Sequence>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="false"/>
      <Fallback>
        <SubTree ID="rmuc_2026_attack_outpost_once"/>
        <SubTree ID="rmuc_2026_activate_power_rune_if_ready"/>
        <SubTree ID="rmuc_2026_enter_highland"/>
      </Fallback>
    </Sequence>
  </BehaviorTree>

</root>
