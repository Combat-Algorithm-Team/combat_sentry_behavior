<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <BehaviorTree ID="rmuc_2026_attack_outpost_once">
    <Sequence>
      <!-- 前哨站只尝试一次；成功后写任务标志，后续主循环会跳过该分支。 -->
      <CheckMissionFlag flag="rmuc_outpost_attack_done"
                        expected="false"/>
      <PublishTargetMode cmd_target_mode="2"
                         duration="0.0"
                         topic_name="cmd_target_mode"/>
      <PubNav2Goal goal="{@rmuc_enemy_outpost_attack_goal}"
                   topic_name="goal_pose"/>
      <WaitForTargetLostStable target_id="8"
                               lost_duration="10000.0"
                               key_port="{@tracker_target}"/>
      <PublishTargetMode cmd_target_mode="1"
                         duration="0.0"
                         topic_name="cmd_target_mode"/>
      <SetMissionFlag flag="rmuc_outpost_attack_done"
                      value="true"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_small_power_rune_ready">
    <Sequence>
      <CheckMissionFlag flag="rmuc_enable_small_power_rune_activation"
                        expected="true"/>
      <CheckMissionCounter counter="rmuc_small_power_rune_activation_failures"
                           max_count="2"/>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="false"/>
      <IsGameStatus name="RMUC2026SmallPowerRuneTime"
                    max_remain_time="420"
                    min_remain_time="240"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"/>
      <CheckFieldEvent key_port="{@referee_eventData}"
                       ally_small_power_rune="0"/>
      <CheckSentryInfo key_port="{@referee_sentryInfo}"
                       ally_power_rune_state="1"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_activate_power_rune_if_ready">
    <Sequence>
      <!-- 小能量机关窗口可能在导航途中消失，所以到点前持续重检 ready 条件。 -->
      <ReactiveSequence>
        <SubTree ID="rmuc_2026_small_power_rune_ready"/>
        <PubNav2Goal goal="{@rmuc_trapezoid_low_platform_goal}"
                     topic_name="goal_pose"/>
      </ReactiveSequence>
      <PublishTargetMode cmd_target_mode="3"
                         duration="0.0"
                         topic_name="cmd_target_mode"/>
      <ReactiveFallback>
        <Sequence>
          <CheckFieldEvent key_port="{@referee_eventData}"
                           ally_small_power_rune="1"/>
          <PublishTargetMode cmd_target_mode="1"
                             duration="0.0"
                             topic_name="cmd_target_mode"/>
        </Sequence>
        <Sequence>
          <WaitForSentryInfoState expected_state="-1"
                                  ally_power_rune_state="0"
                                  timeout="0.0"
                                  key_port="{@referee_sentryInfo}"/>
          <ReactiveFallback>
            <Sequence>
              <CheckFieldEvent key_port="{@referee_eventData}"
                               ally_small_power_rune="1"/>
              <PublishTargetMode cmd_target_mode="1"
                                 duration="0.0"
                                 topic_name="cmd_target_mode"/>
            </Sequence>
            <ForceFailure>
              <Sequence>
                <WaitForSentryInfoState expected_state="-1"
                                        ally_power_rune_state="1"
                                        timeout="0.0"
                                        key_port="{@referee_sentryInfo}"/>
                <PublishTargetMode cmd_target_mode="1"
                                   duration="0.0"
                                   topic_name="cmd_target_mode"/>
                <IncrementMissionCounter counter="rmuc_small_power_rune_activation_failures"
                                         step="1"
                                         max_count="2"/>
              </Sequence>
            </ForceFailure>
          </ReactiveFallback>
        </Sequence>
      </ReactiveFallback>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_enter_highland">
    <Sequence>
      <CheckMissionFlag flag="rmuc_enable_enter_highland"
                        expected="true"/>
      <SubTree ID="rmuc_2026_reset_target_mode_to_armor"/>
      <SubTree ID="traverse_bump_segment"
               bump_before_goal="{@rmuc_bump_to_highland_before_goal}"
               bump_after_goal="{@rmuc_bump_to_highland_after_goal}"/>
      <SetMissionFlag flag="rmuc_phase_on_highland"
                      value="true"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_hold_fortress_when_highland_disabled">
    <Sequence>
      <CheckMissionFlag flag="rmuc_enable_enter_highland"
                        expected="false"/>
      <CheckMissionFlag flag="rmuc_outpost_attack_done"
                        expected="true"/>
      <SubTree ID="rmuc_2026_reset_target_mode_to_armor"/>
      <PubNav2Goal goal="{@rmuc_fortress_defense_under_highland_goal}"
                   topic_name="goal_pose"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_defend_fortress_under_highland">
    <ReactiveSequence>
      <CheckFieldEvent key_port="{@referee_eventData}"
                       ally_fortress_gain_point="2"/>
      <SubTree ID="rmuc_2026_reset_target_mode_to_armor"/>
      <PubNav2Goal goal="{@rmuc_fortress_defense_under_highland_goal}"
                   topic_name="goal_pose"/>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_under_highland_tasks">
    <Sequence>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="false"/>
      <!-- 低地常规任务优先级：前哨站、禁上高地时守己方堡垒、小能量机关、低地防堡垒，最后才上高地。 -->
      <Fallback>
        <SubTree ID="rmuc_2026_attack_outpost_once"/>
        <SubTree ID="rmuc_2026_hold_fortress_when_highland_disabled"/>
        <SubTree ID="rmuc_2026_activate_power_rune_if_ready"/>
        <SubTree ID="rmuc_2026_defend_fortress_under_highland"/>
        <SubTree ID="rmuc_2026_enter_highland"/>
      </Fallback>
    </Sequence>
  </BehaviorTree>

</root>
