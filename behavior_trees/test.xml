  <!-- 推荐用于联调整棵 RMUC 树：目标点很近，但 yaw 和 target_mode 足够区分当前行为。 -->
  <BehaviorTree ID="test_rmuc_2026_minimal_motion">
    <KeepRunningUntilFailure>
      <ForceSuccess>
        <ReactiveSequence>
          <SubTree ID="rmuc_2026_check_game_start"/>
          <RunOnce then_skip="false">
            <SubTree ID="test_rmuc_2026_minimal_motion_initialize"/>
          </RunOnce>
          <ReactiveParallel success_count="3"
                            failure_count="1">
            <KeepRunningUntilFailure>
              <SubTree ID="rmuc_2026_decide_goal"/>
            </KeepRunningUntilFailure>
            <KeepRunningUntilFailure>
              <SubTree ID="rmuc_2026_control_robot_status"/>
            </KeepRunningUntilFailure>
            <KeepRunningUntilFailure>
