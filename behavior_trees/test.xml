                         value="3.5;5.5;0"/>
          <SetBlackboard output_key="@bump_from_ally_after_goal"
                         value="2.5;6.5;0"/>
          <SubTree ID="traverse_bump_from_ally"
                   bump_from_ally_before_goal="{@bump_from_ally_before_goal}"
