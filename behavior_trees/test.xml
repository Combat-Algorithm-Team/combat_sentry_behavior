  <!-- Nav2 goal 发布/到点测试：PubNav2Goal 只发布，WaitUntilReached 只用 TF 判断是否到点。 -->
  <BehaviorTree ID="test_nav2_goal_wait_a">
    <Sequence>
      <PublishTargetMode cmd_target_mode="1"
                         duration="0.0"
                         topic_name="cmd_target_mode"/>
      <PubNav2Goal goal="{@test_nav2_goal_a}"
                   topic_name="goal_pose"/>
      <WaitUntilReached target="{@test_nav2_goal_a}"
                        tolerance="0.02"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="test_nav2_goal_wait_b">
    <Sequence>
      <PublishTargetMode cmd_target_mode="2"
                         duration="0.0"
                         topic_name="cmd_target_mode"/>
      <PubNav2Goal goal="{@test_nav2_goal_b}"
                   topic_name="goal_pose"/>
      <WaitUntilReached target="{@test_nav2_goal_b}"
                        tolerance="0.02"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="test_nav2_goal_wait_timeout_a">
    <Sequence>
      <PublishTargetMode cmd_target_mode="0"
                         duration="0.0"
                         topic_name="cmd_target_mode"/>
      <ForceSuccess>
        <Timeout msec="700">
          <Sequence>
            <PubNav2Goal goal="{@test_nav2_goal_a}"
                         topic_name="goal_pose"/>
            <WaitUntilReached target="{@test_nav2_goal_a}"
                              tolerance="0.02"/>
          </Sequence>
        </Timeout>
      </ForceSuccess>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="test_nav2_goal_wait_timeout_b">
    <Sequence>
      <PublishTargetMode cmd_target_mode="0"
                         duration="0.0"
                         topic_name="cmd_target_mode"/>
      <ForceSuccess>
        <Timeout msec="700">
          <Sequence>
            <PubNav2Goal goal="{@test_nav2_goal_b}"
                         topic_name="goal_pose"/>
            <WaitUntilReached target="{@test_nav2_goal_b}"
                              tolerance="0.02"/>
          </Sequence>
        </Timeout>
      </ForceSuccess>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="test_nav2_goal_ping_pong_wait">
    <KeepRunningUntilFailure>
      <ForceSuccess>
        <Sequence>
          <SetBlackboard output_key="@test_nav2_goal_a"
                         value="0.45;0.0;0.0"/>
          <SetBlackboard output_key="@test_nav2_goal_b"
                         value="-0.45;0.0;3.1416"/>
          <Sequence>
            <PublishTargetMode cmd_target_mode="1"
                               duration="0.0"
                               topic_name="cmd_target_mode"/>
            <PubNav2Goal goal="{@test_nav2_goal_a}"
                         topic_name="goal_pose"/>
            <WaitUntilReached target="{@test_nav2_goal_a}"
                              tolerance="0.02"/>
          </Sequence>
          <Sequence>
            <PublishTargetMode cmd_target_mode="2"
                               duration="0.0"
                               topic_name="cmd_target_mode"/>
            <PubNav2Goal goal="{@test_nav2_goal_b}"
                         topic_name="goal_pose"/>
            <WaitUntilReached target="{@test_nav2_goal_b}"
                              tolerance="0.02"/>
          </Sequence>
        </Sequence>
      </ForceSuccess>
    </KeepRunningUntilFailure>
  </BehaviorTree>

  <BehaviorTree ID="test_rmuc_2026_initialize_minimal_motion_round_if_needed">
    <Fallback>
      <CheckMissionFlag flag="rmuc_round_initialized"
                        expected="true"/>
      <Sequence>
        <SubTree ID="rmuc_2026_initialize"/>
        <!-- 测试覆盖区：整树低位移目标点。 -->
        <SetBlackboard output_key="@rmuc_supply_goal"
                       value="0.0;0.0;0.0"/>
        <SetBlackboard output_key="@rmuc_enemy_outpost_attack_goal"
                       value="0.18;0.0;0.0"/>
        <SetBlackboard output_key="@rmuc_trapezoid_low_platform_goal"
                       value="0.0;0.18;1.5708"/>
        <SetBlackboard output_key="@rmuc_bump_to_highland_before_goal"
                       value="-0.18;0.18;2.3562"/>
        <SetBlackboard output_key="@rmuc_bump_to_highland_after_goal"
                       value="-0.18;0.0;3.1416"/>
        <SetBlackboard output_key="@rmuc_enemy_bump_from_highland_before_goal"
                       value="-0.18;-0.18;-2.3562"/>
        <SetBlackboard output_key="@rmuc_enemy_bump_from_highland_after_goal"
                       value="0.0;-0.18;-1.5708"/>
        <SetBlackboard output_key="@rmuc_fortress_guard_goal"
                       value="0.18;-0.18;-0.7854"/>
        <SetBlackboard output_key="@rmuc_fortress_defense_on_highland_goal"
                       value="0.12;0.12;0.7854"/>
        <SetBlackboard output_key="@rmuc_fortress_defense_under_highland_goal"
                       value="0.12;-0.12;-0.7854"/>
        <SetBlackboard output_key="@rmuc_enemy_fortress_upper_goal"
                       value="-0.12;0.12;2.3562"/>
        <SetBlackboard output_key="@rmuc_assembly_guard_goal"
                       value="-0.12;-0.12;-2.3562"/>
        <SetBlackboard output_key="@rmuc_outpost_protect_goal"
                       value="0.12;-0.18;-0.9828"/>
      </Sequence>
    </Fallback>
  </BehaviorTree>

  <!--
    低血量抢占/恢复重跑测试：
    1. 健康血量时先进入低地任务，通常会从前哨站任务开始。
    2. 外部发布 referee/robot_status.current_hp < 200 后，rmuc_2026_decide_goal 应切到补给恢复。
    3. 外部发布 current_hp >= 400 后，恢复分支退出，未完成的低地任务应从头重新执行。
  -->
  <BehaviorTree ID="test_rmuc_2026_low_hp_preempt_restart">
    <KeepRunningUntilFailure>
      <ForceSuccess>
        <ReactiveSequence>
          <SubTree ID="test_rmuc_2026_initialize_minimal_motion_round_if_needed"/>
          <ReactiveParallel success_count="3"
                            failure_count="1">
            <KeepRunningUntilFailure>
              <SubTree ID="rmuc_2026_decide_goal"/>
            </KeepRunningUntilFailure>
            <KeepRunningUntilFailure>
              <SubTree ID="rmuc_2026_control_robot_status"/>
            </KeepRunningUntilFailure>
            <KeepRunningUntilFailure>
              <SubTree ID="rmuc_2026_control_sentry_status"/>
            </KeepRunningUntilFailure>
          </ReactiveParallel>
        </ReactiveSequence>
      </ForceSuccess>
    </KeepRunningUntilFailure>
  </BehaviorTree>

