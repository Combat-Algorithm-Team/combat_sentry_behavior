<root BTCPP_format="4">
    <TreeNodesModel>
        <Condition ID="CalculateAttackPose">
            <input_port name="costmap_port" type="nav_msgs::msg::OccupancyGrid_&lt;std::allocator&lt;void&gt; &gt;" default="{@nav_globalCostmap}">GlobalCostmap port on blackboard</input_port>
            <input_port name="tracker_port" type="rm_interfaces::msg::Target_&lt;std::allocator&lt;void&gt; &gt;" default="{@tracker_target}">Vision target port on blackboard</input_port>
            <output_port name="goal" type="Pose3D" default="{attack_pose}">Expected goal pose that send to nav2. Fill with format `x;y;yaw`</output_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Condition>
        <Condition ID="CheckFieldEvent">
            <input_port name="center_gain_point" type="int" default="-1">中心增益点</input_port>
            <input_port name="ally_outpost_gain_point" type="int" default="-1">前哨站增益点</input_port>
            <input_port name="trapezoidal_highland" type="int" default="-1">梯形高地</input_port>
            <input_port name="central_highland" type="int" default="-1">中央高地</input_port>
            <input_port name="ally_big_power_rune" type="int" default="-1">大能量机关</input_port>
            <input_port name="ally_fortress_gain_point" type="int" default="-1">堡垒增益点</input_port>
            <input_port name="ally_small_power_rune" type="int" default="-1">小能量机关</input_port>
            <input_port name="ally_supply_zone" type="int" default="-1">补给区(RMUL)</input_port>
            <input_port name="ally_supply_zone_exchange" type="int" default="-1">补给区(兑换区)</input_port>
            <input_port name="ally_supply_zone_non_exchange" type="int" default="-1">补给区(非兑换区)</input_port>
            <input_port name="base_gain_point" type="int" default="-1">基地增益点</input_port>
            <input_port name="key_port" type="combat_rm_interfaces::msg::EventData_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_eventData}">EventData message</input_port>
        </Condition>
        <Condition ID="CheckTargetInRegion">
            <input_port name="tracker_port" type="rm_interfaces::msg::Target_&lt;std::allocator&lt;void&gt; &gt;" default="{@tracker_target}">Vision target from blackboard</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Condition>
        <Condition ID="IsAttacked">
            <input_port name="hurtdata_port" type="combat_rm_interfaces::msg::HurtData_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_hurtdata}">HurtData port on blackboard</input_port>
            <input_port name="robotstatus_port" type="combat_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsDetectEnemy">
            <input_port name="armor_id" type="std::vector&lt;int, std::allocator&lt;int&gt; &gt;" default="1;2;3;4;5;7">Expected id of armors. Multiple numbers should be separated by the character `;` in Groot2</input_port>
            <input_port name="max_distance" type="float" default="8.000000">Distance to enemy target</input_port>
            <input_port name="key_port" type="rm_interfaces::msg::Armors_&lt;std::allocator&lt;void&gt; &gt;" default="{@detector_armors}">Vision detector port on blackboard</input_port>
        </Condition>
        <Condition ID="IsGameStatus">
            <input_port name="max_remain_time" type="int" default="420">Maximum remaining time (s)</input_port>
            <input_port name="min_remain_time" type="int" default="0">Minimum remaining time (s)</input_port>
            <input_port name="expected_game_progress" type="int" default="4">Expected game progress stage</input_port>
            <input_port name="key_port" type="combat_rm_interfaces::msg::GameStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_gameStatus}">GameStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsGoalAvailable">
            <input_port name="goal" type="Pose3D" default="{candidate_pose}">Expected goal pose that send to nav2. Fill with format `x;y;yaw`</input_port>
            <input_port name="max_y" type="float" default="8.0">the maximum y coordinate of the goal position</input_port>
            <input_port name="max_x" type="float" default="8.0">the maximum x coordinate of the goal position</input_port>
        </Condition>
        <Condition ID="IsRfidDetected">
            <input_port name="center_gain_point" type="bool" default="false">中心增益点（仅 RMUL 适用）</input_port>
            <input_port name="ally_supply_point_non_exchange" type="bool" default="false">己方与兑换区不重叠的补给区 / RMUL 补给区</input_port>
            <input_port name="key_port" type="combat_rm_interfaces::msg::RfidStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_rfidStatus}">RfidStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsStatusOK">
            <input_port name="hp_max" type="int" default="399">Maximum HP. NOTE: Sentry init/max HP is 400</input_port>
            <input_port name="hp_min" type="int" default="200">Minimum HP. NOTE: Sentry init/max HP is 400</input_port>
            <input_port name="key_port" type="combat_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="PubNav2Goal">
            <input_port name="goal" type="Pose3D" default="0;0;0">Expected goal pose that send to nav2. Fill with format `x;y;yaw`</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Condition>
        <Action ID="PublishChassisStatus">
            <input_port name="chassis_status" type="unsigned char" default="0">Chassis status (0-5)</input_port>
            <input_port name="duration" type="std::chrono::milliseconds" default="">Publish then sleep duration in milliseconds</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Action>
        <Action ID="PublishSentryStatus">
            <input_port name="sentry_status" type="unsigned char" default="0">Sentry status (0-5)</input_port>
            <input_port name="duration" type="std::chrono::milliseconds" default="">Publish then sleep duration in milliseconds</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Action>
        <Action ID="PublishTwist">
            <input_port name="v_y" type="double" default="0.000000">Linear Y velocity (m/s)</input_port>
            <input_port name="v_yaw" type="double" default="0.000000">Angular Z velocity (rad/s)</input_port>
            <input_port name="v_x" type="double" default="0.000000">Linear X velocity (m/s)</input_port>
            <input_port name="duration" type="std::chrono::milliseconds" default="">Publish then sleep duration in milliseconds</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Action>
        <Decorator ID="RateController">
            <input_port name="hz" type="double" default="10.000000">Rate</input_port>
        </Decorator>
        <Control ID="RecoveryNode">
            <input_port name="num_attempts" type="int" default="999">Number of retries</input_port>
        </Control>
        <Action ID="SendNav2Goal">
            <input_port name="goal" type="Pose3D" default="0;0;0">Expected goal pose that send to nav2. Fill with format `x;y;yaw`</input_port>
            <input_port name="action_name" type="std::string" default="">Action server name</input_port>
        </Action>
        <Decorator ID="TickAfterTimeout">
            <input_port name="timeout" type="float">time in s to wait before ticking child again</input_port>
        </Decorator>
    </TreeNodesModel>
</root>
