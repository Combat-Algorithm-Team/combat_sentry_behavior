<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <BehaviorTree ID="rmuc_2026_final_two_minute_fortress_attack">
    <Sequence>
      <CheckMissionFlag flag="rmuc_enable_final_two_minute_fortress_attack"
                        expected="true"/>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="true"/>
      <IsGameStatus name="RMUC2026FinalTwoMinuteFortressAttackTime"
                    max_remain_time="120"
                    min_remain_time="0"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"/>
      <SubTree ID="rmuc_2026_reset_target_mode_to_armor"/>
      <Fallback>
        <Sequence>
          <CheckMissionFlag flag="rmuc_phase_enemy_fortress_attack"
                            expected="true"/>
          <PubNav2Goal goal="{@rmuc_enemy_fortress_upper_goal}"
                       topic_name="goal_pose"/>
          <WaitUntilReached target="{@rmuc_enemy_fortress_upper_goal}"/>
        </Sequence>
        <Sequence>
          <SubTree ID="traverse_bump_segment"
                   bump_before_goal="{@rmuc_enemy_bump_from_highland_before_goal}"
                   bump_after_goal="{@rmuc_enemy_bump_from_highland_after_goal}"/>
          <SetMissionFlag flag="rmuc_phase_enemy_fortress_attack"
                          value="true"/>
          <PubNav2Goal goal="{@rmuc_enemy_fortress_upper_goal}"
                       topic_name="goal_pose"/>
          <WaitUntilReached target="{@rmuc_enemy_fortress_upper_goal}"/>
        </Sequence>
      </Fallback>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026_on_highland_tasks">
    <Sequence>
      <CheckMissionFlag flag="rmuc_phase_on_highland"
                        expected="true"/>
      <SubTree ID="rmuc_2026_reset_target_mode_to_armor"/>
      <ReactiveFallback>
        <ReactiveSequence>
          <CheckFieldEvent key_port="{@referee_eventData}"
                           ally_fortress_gain_point="2"/>
          <Sequence>
            <PubNav2Goal goal="{@rmuc_fortress_defense_on_highland_goal}"
                         topic_name="goal_pose"/>
            <WaitUntilReached target="{@rmuc_fortress_defense_on_highland_goal}"/>
          </Sequence>
        </ReactiveSequence>
        <ReactiveSequence>
          <IsOutpostHpLow hp_threshold="500"
                          key_port="{@referee_gameRobotHp}"/>
          <Sequence>
            <PubNav2Goal goal="{@rmuc_outpost_protect_goal}"
                         topic_name="goal_pose"/>
            <WaitUntilReached target="{@rmuc_outpost_protect_goal}"/>
          </Sequence>
        </ReactiveSequence>
        <Sequence>
          <PubNav2Goal goal="{@rmuc_assembly_guard_goal}"
                       topic_name="goal_pose"/>
          <WaitUntilReached target="{@rmuc_assembly_guard_goal}"/>
        </Sequence>
      </ReactiveFallback>
    </Sequence>
  </BehaviorTree>

</root>
